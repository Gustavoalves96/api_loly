FRONTEND_ORIGIN=http://localhost:5173
PORT=3000
DATABASE_URL=postgres://user:password@host:5432/dbname

# Segredo para assinar os tokens JWT (obrigatório, mínimo 16 caracteres)
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio

# Senha do admin. Use UMA das opções abaixo:
# 1) Texto puro (mais simples):
ADMIN_PASSWORD=defina-uma-senha-forte
# 2) Hash scrypt no formato "salt:hashHex" (mais seguro, recomendado em produção):
# ADMIN_PASSWORD_HASH=
